{
  "name": "bagger-flow",
  "displayName": "Bagger Flow Theme",
  "description": "Modern, colorful and slick dark theme for Visual Studio Code and compatible editors.",
  "version": "0.1.2",
  "publisher": "kikogoncalves",
  "author": "Francisco Gonçalves",
  "repository": {
    "type": "git",
    "url": "https://github.com/kiko-g/bagger-flow-vscode"
  },
  "homepage": "https://www.kikogoncalves.com",
  "scripts": {
    "generate": "node scripts/generate-themes.js",
    "build": "npm run generate && vsce package",
    "publish:vscode": "vsce publish -p $VSCE_PAT",
    "publish:ovsx": "ovsx publish bagger-flow-$npm_package_version.vsix -p $OVSX_PAT",
    "publish": "npm run build && npm run publish:vscode && npm run publish:ovsx"
  },
  "engines": {
    "vscode": "^1.14.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "dark",
    "tailwind",
    "syntax",
    "slick",
    "modern",
    "minimal",
    "colorful"
  ],
  "icon": "logo.png",
  "contributes": {
    "themes": [
      {
        "label": "Bagger Flow Dark Navy (default)",
        "uiTheme": "vs-dark",
        "path": "themes/bagger-flow-dark-navy.json"
      },
      {
        "label": "Bagger Flow Dark Gray",
        "uiTheme": "vs-dark",
        "path": "themes/bagger-flow-dark-gray.json"
      },
      {
        "label": "Bagger Flow Dark Cherry",
        "uiTheme": "vs-dark",
        "path": "themes/bagger-flow-dark-cherry.json"
      },
      {
        "label": "Bagger Flow Dark Teal",
        "uiTheme": "vs-dark",
        "path": "themes/bagger-flow-dark-teal.json"
      }
    ]
  },
  "devDependencies": {
    "@vscode/vsce": "^3.7.1",
    "ovsx": "^0.10.10"
  }
}
